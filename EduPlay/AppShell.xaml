<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="EduPlay.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:EduPlay.Views"
    BackgroundColor="#0A0A0F"
    FlyoutBehavior="Disabled"
    TabBarBackgroundColor="#13131A"
    TabBarUnselectedColor="#8888A8"
    TabBarTitleColor="#7C5CFF">

    <TabBar>
        <ShellContent
            Title="Build"
            ContentTemplate="{DataTemplate views:BuildPage}"
            Route="BuildPage">
            <ShellContent.Icon>
                <FontImageSource Glyph="&#x2B50;" FontFamily="OpenSansRegular" Color="#7C5CFF" />
            </ShellContent.Icon>
        </ShellContent>

        <ShellContent
            Title="My Games"
            ContentTemplate="{DataTemplate views:LibraryPage}"
            Route="LibraryPage">
            <ShellContent.Icon>
                <FontImageSource Glyph="&#x1F3AE;" FontFamily="OpenSansRegular" Color="#8888A8" />
            </ShellContent.Icon>
        </ShellContent>
    </TabBar>

</Shell>